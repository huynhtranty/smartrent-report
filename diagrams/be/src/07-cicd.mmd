flowchart TB
    Dev(["Lập trình viên"])
    GH["GitHub<br/><small>nhánh feature, pull request vào main</small>"]

    subgraph CI["GitHub Actions - CI (trên pull request)"]
        direction LR
        B["Biên dịch"] --> T["Kiểm thử đơn vị + độ phủ"]
    end

    subgraph CD["GitHub Actions - CD (khi hợp nhất vào main)"]
        direction LR
        Img["Đóng gói Docker image"] --> Push["Đẩy lên Docker Hub"] --> Hook["Gọi webhook Dokploy"]
    end

    Dok["Dokploy<br/><small>kéo ảnh mới từ Docker Hub, tạo lại container</small>"]
    Droplet["Máy chủ DigitalOcean Droplet<br/><small>Traefik định tuyến, HTTPS</small>"]

    Dev -->|"push / pull request"| GH
    GH -->|"pull request"| CI
    CI -->|"đạt, hợp nhất main"| CD
    CD --> Dok
    Dok --> Droplet
